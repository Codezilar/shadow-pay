generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CREATOR
  STUDENT
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(CREATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creatorProfile     CreatorProfile?
  studentEnrollments StudentEnrollment[]
  communityMessages  CommunityMessage[]
  communityComments  CommunityComment[]
  communityMessageLikes CommunityMessageLike[]
  communityCommentLikes CommunityCommentLike[]
}

model CreatorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug        String @unique
  displayName String
  bio         String @default("")

  /// Percentage of the charged amount that belongs to the creator (0–100). The remainder is the platform share.
  creatorSharePercent Int @default(70)

  /// Optional Paystack Transaction Split code from your Paystack dashboard (per-creator or shared group).
  paystackSplitCode String?

  /// Creator subaccount code from Paystack (often required when building splits).
  paystackSubaccountCode String?

  approved Boolean @default(false)

  /// JSON array of payment amounts (in NGN) that this creator accepts. E.g., [5000, 10000, 50000]. If empty, allow dynamic amounts.
  paymentAmountsJson String @default("[]")

  /// Course title to display on payment page
  courseTitle String @default("")

  /// Course description to display on payment page
  courseDescription String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions      Transaction[]
  studentEnrollments StudentEnrollment[]
  withdrawalRequests WithdrawalRequest[]
  communityMessages  CommunityMessage[]
  communityComments  CommunityComment[]
}

model Transaction {
  id                String @id @default(cuid())
  paystackReference String @unique

  amountKobo Int
  currency   String @default("NGN")
  status     String @default("pending")

  creatorSharePercentSnapshot Int
  creatorAmountKobo           Int?
  platformAmountKobo          Int?

  customerEmail String?
  metadata      Json?

  creatorProfileId String
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentEnrollment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  creatorProfileId String
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  customerEmail String
  lastReference String
  lastPaidAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessTokens      CommunityAccessToken[]
  communityMessages CommunityMessage[]
  communityComments CommunityComment[]

  @@unique([userId, creatorProfileId])
}

model CommunityAccessToken {
  id String @id @default(cuid())

  token String @unique

  enrollmentId String
  enrollment   StudentEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model CommunityMessage {
  id String @id @default(cuid())

  creatorProfileId String
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  authorUserId String?
  authorUser   User? @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  authorEnrollmentId String?
  authorEnrollment   StudentEnrollment? @relation(fields: [authorEnrollmentId], references: [id], onDelete: SetNull)

  authorName String
  authorRole Role
  body       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CommunityComment[]
  likes    CommunityMessageLike[]
}

model CommunityComment {
  id String @id @default(cuid())

  creatorProfileId String
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  messageId String
  message   CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  parentId String?
  parent   CommunityComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  CommunityComment[] @relation("CommentReplies")

  authorUserId String?
  authorUser   User? @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  authorEnrollmentId String?
  authorEnrollment   StudentEnrollment? @relation(fields: [authorEnrollmentId], references: [id], onDelete: SetNull)

  authorName String
  authorRole Role
  body       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes CommunityCommentLike[]
}

model CommunityMessageLike {
  id String @id @default(cuid())

  messageId String
  message   CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId])
}

model CommunityCommentLike {
  id String @id @default(cuid())

  commentId String
  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([commentId, userId])
}

model WithdrawalRequest {
  id String @id @default(cuid())

  creatorProfileId String
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  amountKobo Int
  status     WithdrawalStatus @default(PENDING)
  adminNote  String           @default("")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
}

model EmailDeliveryLog {
  id String @id @default(cuid())

  eventKey  String @unique
  eventType String
  recipient String
  status    EmailDeliveryStatus @default(SENT)
  error     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
