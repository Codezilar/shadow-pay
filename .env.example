# SQLite (dev). For production, switch prisma/schema.prisma provider to postgresql and set a Postgres URL.
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Public URL used for Paystack callback (must match what Paystack can reach)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# Optional: seed admin (see package.json db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme-now"
