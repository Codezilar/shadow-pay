# PostgreSQL / Prisma Accelerate connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Public URL used for Paystack callback (must match what Paystack can reach)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# Optional: seed admin (see package.json db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme-now"

EMAIL_FROM="NexaPay Official <nexafoz@gmail.com>"
EMAIL_REPLY_TO="nexafoz@gmail.com"
SUPPORT_EMAIL="nexafoz@gmail.com"
RESEND_API_KEY=""
NEXT_PUBLIC_IOS_APP_URL="https://apps.apple.com/app/id0000000000"
NEXT_PUBLIC_ANDROID_APP_URL="https://play.google.com/store/apps/details?id=com.nexapay.official"
